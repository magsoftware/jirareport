JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=your.email@example.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_SPACES_CONFIG_PATH=config/spaces.yaml

# Jira reporting spaces, slugs, and yearly spreadsheet IDs are configured in
# config/spaces.yaml

REPORT_TIMEZONE=Europe/Warsaw

# Storage backend: local or gcs
REPORT_STORAGE_BACKEND=local

# Local storage settings
REPORT_OUTPUT_DIR=reports

# GCP Service Account key file
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/your/service-account-key.json

# Google Cloud Storage settings
GCS_BUCKET_NAME=your-gcs-bucket
GCS_BUCKET_PREFIX=jirareport

# Google Sheets integration
# GOOGLE_SHEETS_ENABLED=true
# GOOGLE_SHEETS_TITLE_PREFIX=Jira Worklog Analytics

# Google BigQuery integration
# BIGQUERY_ENABLED=true
# BIGQUERY_PROJECT_ID=jira-report-489919
# BIGQUERY_DATASET=jirareport
# BIGQUERY_TABLE=worklogs